{
	"compilerOptions": {
		"strict": true,

		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["vite/client"],

		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,

		"jsx": "react-jsx",
		"lib": ["DOM", "DOM.Iterable", "ES2023"],
		"target": "ES2022",

		"skipLibCheck": true
	},
	"include": ["**/*", ".storybook/**/*"]
}
